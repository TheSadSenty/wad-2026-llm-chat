LLM_CHAT_APP__HOST=127.0.0.1
LLM_CHAT_APP__PORT=8000

# Required for JWT signing.
# LLM_CHAT_AUTH__JWT_SECRET=
LLM_CHAT_AUTH__ACCESS_TOKEN_TTL_MINUTES=60
LLM_CHAT_AUTH__REFRESH_TOKEN_TTL_DAYS=30

# Optional GitHub OAuth.
# LLM_CHAT_AUTH__GITHUB__CLIENT_ID=
# LLM_CHAT_AUTH__GITHUB__CLIENT_SECRET=
# LLM_CHAT_AUTH__GITHUB__ALLOW_SIGNUP=true

# Postgres
LLM_CHAT_DATABASE__POSTGRES__HOST=127.0.0.1
LLM_CHAT_DATABASE__POSTGRES__PORT=5432
LLM_CHAT_DATABASE__POSTGRES__DBNAME=llm-chat
# LLM_CHAT_DATABASE__POSTGRES__USER=postgres
# LLM_CHAT_DATABASE__POSTGRES__PASSWORD=changethis

# LLM
LLM_CHAT_LLM__GGUF_PATH=./qwen.gguf

# Redis
LLM_CHAT_REDIS__HOST=127.0.0.1
LLM_CHAT_REDIS__PORT=6379
LLM_CHAT_REDIS__DB=0
# LLM_CHAT_REDIS__PASSWORD=
